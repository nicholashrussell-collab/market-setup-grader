# Alpaca market data
APCA_API_KEY_ID=your_alpaca_key_id
APCA_API_SECRET_KEY=your_alpaca_secret_key
ALPACA_DATA_FEED=iex

# Supabase server-side database access
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_or_service_role_key

# Optional: Vercel cron protection. Vercel sends Authorization: Bearer $CRON_SECRET for cron calls.
CRON_SECRET=make-a-random-secret
BOT_CRON_SECRET=make-a-random-secret

# Cloud paper bot settings
BOT_ENABLED=true
BOT_PAPER_TRADING_ENABLED=true
BOT_UNIVERSE=Super Wide 100
BOT_TIMEFRAME=15Min
BOT_MIN_SCORE=80
BOT_MAX_SCORE=89
BOT_MIN_RR=1
BOT_MAX_STALE_MINUTES=30
BOT_MAX_OPEN_POSITIONS=4
BOT_STARTING_EQUITY=5000
BOT_RISK_PCT=1
BOT_MAX_POSITION_PCT=25
BOT_LONG_ONLY=true
BOT_ALLOW_STALE_SIMULATION=false
# Optional custom universe. Leave blank to use BOT_UNIVERSE.
# BOT_SYMBOLS=AAPL,MSFT,NVDA,SPY,QQQ
