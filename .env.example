# Copy this file to .env.local and put it in the same folder as package.json.
# Do not paste these keys into ChatGPT.

# Alpaca is useful for paper/live workflow.
APCA_API_KEY_ID=your_alpaca_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_here

# Free/basic Alpaca users should usually use iex.
# If you pay for full SIP data, change to sip.
ALPACA_DATA_FEED=iex

# Massive is useful for recent multi-year intraday backtesting.
MASSIVE_API_KEY=your_massive_key_here
