# Alpaca market data + paper broker bridge
APCA_API_KEY_ID=your_alpaca_key_id
APCA_API_SECRET_KEY=your_alpaca_secret_key
ALPACA_DATA_FEED=iex
# Required for Alpaca Paper broker bridge. Keep this as paper-api unless you intentionally change code later.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Supabase server-side database access
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_or_service_role_key

# Private admin page
# Use this to unlock /admin. Do not put it in GitHub.
ADMIN_PASSWORD=choose-a-private-password
ADMIN_SESSION_SECRET=make-a-random-long-secret

# Optional: Vercel cron protection for direct bot endpoint access.
CRON_SECRET=make-a-random-secret
BOT_CRON_SECRET=make-a-random-secret

# Cloud paper bot defaults. v8.4 can override most of these from /admin via Supabase bot_control.
BOT_ENABLED=true
BOT_PAPER_TRADING_ENABLED=false
BOT_UNIVERSE=Tracked Symbols
BOT_TIMEFRAME=15Min
BOT_MIN_SCORE=80
BOT_MAX_SCORE=89
BOT_MIN_RR=1
BOT_MAX_STALE_MINUTES=30
BOT_MAX_OPEN_POSITIONS=4
BOT_STARTING_EQUITY=5000
BOT_RISK_PCT=1
BOT_MAX_POSITION_PCT=25
BOT_LONG_ONLY=true
BOT_ALLOW_STALE_SIMULATION=false
# Optional custom universe. Leave blank to use BOT_UNIVERSE.
# BOT_SYMBOLS=AAPL,MSFT,NVDA,SPY,QQQ

# Broker bridge defaults. Admin settings can override these from Supabase bot_control.
BOT_BROKER_MODE=Supabase Simulation
BOT_BROKER_PAPER_ENABLED=false
BOT_BROKER_LIVE_ENABLED=false

# Optional Alpaca Paper-specific credentials. If these are not set, v8.4 falls back to APCA_API_KEY_ID / APCA_API_SECRET_KEY.
ALPACA_PAPER_API_KEY_ID=your_alpaca_paper_key_id
ALPACA_PAPER_API_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Optional live-broker readiness. Do not set these until you intentionally want live-trading capability available.
ALPACA_LIVE_API_KEY_ID=your_alpaca_live_key_id
ALPACA_LIVE_API_SECRET_KEY=your_alpaca_live_secret_key
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
LIVE_TRADING_UNLOCKED=false
LIVE_TRADING_CONFIRMATION=NOT_UNLOCKED
